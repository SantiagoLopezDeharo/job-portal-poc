{
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "src/index.ts",
	"name": "job-portal-poc",
	"upload_source_maps": true,
	"observability": {
		"enabled": true
	},
	"r2_buckets": [
		{
			"binding": "CV_BUCKET",
			"bucket_name": "job-portal-cv-bucket",
			"remote": false
		}
	],
	"queues": {
		"producers": [
			{
				"binding": "MATCH_QUEUE",
				"queue": "application-match-score-queue"
			}
		],
		"consumers": [
			{
				"queue": "application-match-score-queue",
				"max_batch_size": 10,
				"max_batch_timeout": 5
			},
			{
				"queue": "cv-object-events-queue",
				"max_batch_size": 10,
				"max_batch_timeout": 5
			}
		]
	}
}